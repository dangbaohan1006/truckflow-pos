{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^\\/order\\.html", "dest": "/order.html" },
    { "src": "\\/(.*)", "dest": "/index.html" }
  ]
}
